{
    "name": "@stationary/server",
    "type": "module",
    "scripts": {
        "dev": "bun run --hot src/index.ts",
        "typecheck": "bun run tsgo --noEmit",
        "build": "bun build src/index.ts --outdir ./dist --target bun",
        "deploy": "bunx wrangler deploy",
        "worker:dev": "bunx wrangler dev",
        "db:migrate": "bunx drizzle-kit generate && bunx drizzle-kit push",
        "docker:build": "docker build --platform linux/amd64 -f Dockerfile -t stationary:latest ../.."
    },
    "dependencies": {
        "@ai-sdk/google": "^4.0.17",
        "@ai-sdk/openai": "^4.0.15",
        "@aws-sdk/client-s3": "^3.1088.0",
        "@aws-sdk/lib-storage": "^3.1088.0",
        "@aws-sdk/s3-request-presigner": "^3.1088.0",
        "@hono/zod-validator": "^0.9.0",
        "@js-temporal/polyfill": "^0.5.1",
        "@upstash/workflow": "^1.3.3",
        "ai": "^7.0.29",
        "better-auth": "^1.6.23",
        "drizzle-orm": "^1.0.0-rc.4",
        "hono": "^4.12.30",
        "ky": "^2.0.2",
        "pg": "^8.22.0",
        "redis": "^6.1.0",
        "resend": "^6.17.2",
        "temporal-polyfill": "^1.0.0",
        "uuid": "^14.0.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^5.20260716.1",
        "@types/bun": "latest",
        "@types/pg": "latest",
        "@types/uuid": "^11.0.0",
        "drizzle-kit": "^1.0.0-rc.3"
    }
}